# Database Configuration
DATABASE_URL=postgresql://tinyurl_user:tinyurl_password@localhost:5432/tinyurl?sslmode=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Application Configuration
BASE_URL=http://localhost:8080
PORT=8080

# Service Configuration
MIN_SHORT_CODE_LENGTH=6
CACHE_TTL=3600
STATS_CACHE_TTL=300
ENABLE_DEDUPLICATION=true
